<?xml version="1.0" encoding="utf-8"?>
<!-- SIMJ self-hosted cloud uses HTTP (not HTTPS). Allow cleartext globally so login works. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
